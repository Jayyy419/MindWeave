# Database connection string
# REQUIRED: Use PostgreSQL (RDS/Aurora) for production and development
# DEPRECATED: Local SQLite (file:./dev.db) support has been removed
DATABASE_URL="postgresql://mindweave_user:CHANGE_ME@mindweave-db.xxxxxx.ap-southeast-1.rds.amazonaws.com:5432/mindweave?schema=public"

# App settings
PORT=3001
CORS_ORIGIN="https://your-cloudfront-domain.cloudfront.net"
JWT_SECRET="CHANGE_ME_TO_LONG_RANDOM_SECRET"
FRONTEND_BASE_URL="https://your-cloudfront-domain.cloudfront.net"

# Optional one-time admin bootstrap (disabled by default for safety)
ENABLE_ADMIN_BOOTSTRAP="false"
# ADMIN_BOOTSTRAP_IDENTIFIER can be an email or username
ADMIN_BOOTSTRAP_IDENTIFIER=""

# Auth hardening
AUTH_RATE_LIMIT_WINDOW_MS=600000
AUTH_LOGIN_RATE_LIMIT_MAX=10
AUTH_FORGOT_RATE_LIMIT_MAX=5
AUTH_LOCKOUT_MAX_ATTEMPTS=5
AUTH_LOCKOUT_MINUTES=15

# SMTP (required for forgot-password email)
SMTP_HOST="smtp.your-provider.com"
SMTP_PORT=587
SMTP_USER="smtp-username"
SMTP_PASS="smtp-password"
SMTP_FROM="MindWeave <no-reply@your-domain.com>"

# AI
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"
GEMINI_MODEL="gemini-2.5-flash"

# Optional AI cost estimation tuning (USD per 1M tokens)
AI_INPUT_COST_PER_MILLION=0.15
AI_OUTPUT_COST_PER_MILLION=0.6
