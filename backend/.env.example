# PostgreSQL connection string (RDS/Aurora)
DATABASE_URL="postgresql://mindweave_user:CHANGE_ME@mindweave-db.xxxxxx.ap-southeast-1.rds.amazonaws.com:5432/mindweave?schema=public"

# App settings
PORT=3001
CORS_ORIGIN="https://your-cloudfront-domain.cloudfront.net"
JWT_SECRET="CHANGE_ME_TO_LONG_RANDOM_SECRET"
FRONTEND_BASE_URL="https://your-cloudfront-domain.cloudfront.net"

# SMTP (required for forgot-password email)
SMTP_HOST="smtp.your-provider.com"
SMTP_PORT=587
SMTP_USER="smtp-username"
SMTP_PASS="smtp-password"
SMTP_FROM="MindWeave <no-reply@your-domain.com>"

# AI
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"
