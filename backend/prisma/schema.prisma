// Prisma schema for MindWeave
// PostgreSQL (AWS RDS) is the required database provider
// Local SQLite development database support has been deprecated

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Represents an anonymous user identified by a browser-generated UUID
model User {
  id           String       @id @default(cuid())
  anonymousId  String?      @unique
  email        String?      @unique
  username     String?      @unique
  passwordHash String?
  level        Int          @default(1)
  badges       String       @default("[]") // JSON array of badge names
  tags         String       @default("[]") // JSON array of accumulated tags
  isAdmin      Boolean      @default(false)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  entries      Entry[]
  memberships  Membership[]
  messages     Message[]
  resetTokens  PasswordResetToken[]
  consents     DataAccessConsent[]
  lessonProgress LearningLessonProgress[]
  surveyResponses SurveyResponse[]
}

/// One-time password reset token sent via email
model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([expiresAt])
}

/// A journal entry with original text and AI-reframed text
model Entry {
  id           String   @id @default(cuid())
  userId       String
  framework    String   // "cbt" | "iceberg" | "growth"
  title        String   @default("")
  originalText String
  reframedText String
  chunks       String   @default("[]") // JSON array of { id, userText, aiText }
  tags         String   @default("[]") // JSON array of extracted tags for this entry
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id])
}

/// A predefined think tank (collaborative group)
model ThinkTank {
  id          String       @id @default(cuid())
  name        String       @unique
  description String
  tags        String       @default("[]") // JSON array of interest tags
  maxMembers  Int          @default(5)
  memberships Membership[]
  messages    Message[]
}

/// A competition, resource pathway, or organiser-led opportunity surfaced through MindWeave.
model Opportunity {
  id                 String              @id @default(cuid())
  slug               String              @unique
  title              String
  organizerName      String
  summary            String
  description        String
  benefits           String              @default("[]")
  resourceHighlights String              @default("[]")
  requestedScopes    String              @default("[]")
  matchingTags       String              @default("[]")
  minimumEntries     Int                 @default(3)
  minimumLevel       Int                 @default(1)
  isActive           Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  consents           DataAccessConsent[]
}

/// A user's explicit consent to share a bounded profile package with an opportunity organiser.
model DataAccessConsent {
  id                String      @id @default(cuid())
  userId            String
  opportunityId     String
  status            String      @default("granted")
  scopes            String      @default("[]")
  purposeSnapshot   String
  organizerSnapshot String
  expiresAt         DateTime?
  grantedAt         DateTime    @default(now())
  revokedAt         DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  opportunity       Opportunity @relation(fields: [opportunityId], references: [id])
  user              User        @relation(fields: [userId], references: [id])

  @@unique([userId, opportunityId])
  @@index([userId, status])
}

/// Links a user to a think tank they've joined
model Membership {
  id          String    @id @default(cuid())
  userId      String
  thinkTankId String
  joinedAt    DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id])
  thinkTank   ThinkTank @relation(fields: [thinkTankId], references: [id])

  @@unique([userId, thinkTankId])
}

/// Messages posted in a think tank chat room by users or AI bot
model Message {
  id               String    @id @default(cuid())
  thinkTankId      String
  userId           String?
  role             String    @default("user") // "user" | "bot"
  usernameSnapshot String
  content          String
  createdAt        DateTime  @default(now())
  thinkTank        ThinkTank @relation(fields: [thinkTankId], references: [id])
  user             User?     @relation(fields: [userId], references: [id])
}

/// Tracks completed learning-library lessons for each user.
model LearningLessonProgress {
  id          String   @id @default(cuid())
  userId      String
  frameworkId String
  lessonId    String
  completedAt DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])

  @@unique([userId, lessonId])
  @@index([userId, frameworkId])
}

/// A survey template with questions and metadata
model Survey {
  id          String   @id @default(cuid())
  title       String
  description String
  type        String   @default("wellbeing") // "wellbeing", "outcome", "feedback"
  questions   String   // JSON array of { id, text, responseType, options?, required? }
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  responses   SurveyResponse[]

  @@index([type])
}

/// A user's response to a survey
model SurveyResponse {
  id          String   @id @default(cuid())
  userId      String
  surveyId    String
  responses   String   // JSON object of { questionId: answer }
  submittedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])
  survey      Survey   @relation(fields: [surveyId], references: [id])

  @@unique([userId, surveyId])
  @@index([userId, surveyId, submittedAt])
}
