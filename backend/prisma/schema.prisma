// Prisma schema for MindWeave
// PostgreSQL-ready for AWS RDS deployment

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Represents an anonymous user identified by a browser-generated UUID
model User {
  id           String       @id @default(cuid())
  anonymousId  String?      @unique
  email        String?      @unique
  username     String?      @unique
  passwordHash String?
  level        Int          @default(1)
  badges       String       @default("[]") // JSON array of badge names
  tags         String       @default("[]") // JSON array of accumulated tags
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  entries      Entry[]
  memberships  Membership[]
  messages     Message[]
  resetTokens  PasswordResetToken[]
}

/// One-time password reset token sent via email
model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([expiresAt])
}

/// A journal entry with original text and AI-reframed text
model Entry {
  id           String   @id @default(cuid())
  userId       String
  framework    String   // "cbt" | "iceberg" | "growth"
  title        String   @default("")
  originalText String
  reframedText String
  chunks       String   @default("[]") // JSON array of { id, userText, aiText }
  tags         String   @default("[]") // JSON array of extracted tags for this entry
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id])
}

/// A predefined think tank (collaborative group)
model ThinkTank {
  id          String       @id @default(cuid())
  name        String       @unique
  description String
  tags        String       @default("[]") // JSON array of interest tags
  maxMembers  Int          @default(5)
  memberships Membership[]
  messages    Message[]
}

/// Links a user to a think tank they've joined
model Membership {
  id          String    @id @default(cuid())
  userId      String
  thinkTankId String
  joinedAt    DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id])
  thinkTank   ThinkTank @relation(fields: [thinkTankId], references: [id])

  @@unique([userId, thinkTankId])
}

/// Messages posted in a think tank chat room by users or AI bot
model Message {
  id               String    @id @default(cuid())
  thinkTankId      String
  userId           String?
  role             String    @default("user") // "user" | "bot"
  usernameSnapshot String
  content          String
  createdAt        DateTime  @default(now())
  thinkTank        ThinkTank @relation(fields: [thinkTankId], references: [id])
  user             User?     @relation(fields: [userId], references: [id])
}
